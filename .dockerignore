# Root-context Docker builds should only see the files used by
# `docker/runtime.dockerfile` and `docker/backend.dockerfile`.
# Keep this as an explicit allowlist so large sibling trees do not
# accidentally inflate hosted smoke and image build loops.
*
!.dockerignore
!bun.lock

!server/
!server/**

!web/
!web/**

!config/
config/*
!config/models.json

!docker/
docker/*
!docker/backend.dockerfile
!docker/runtime.dockerfile
!docker/entrypoint.sh

# Build identity is generated per-build by scripts/build/generate_build_identity.py
# and staged directly into server/zerg/build_identity.json, so it rides along
# via the `!server/` allowlist above — no extra .build/ allowlist needed.

# Ignore heavyweight/generated content inside the allowlisted trees.
server/.venv
server/.venv/**
server/.uv_cache
server/.uv_cache/**
server/.uv_tmp
server/.uv_tmp/**
server/venv
server/venv/**
server/dist
server/dist/**
server/data
server/data/**
server/.pytest_cache
server/.pytest_cache/**
server/.ruff_cache
server/.ruff_cache/**
server/__pycache__
server/__pycache__/**

web/node_modules
web/node_modules/**
web/dist
web/dist/**
