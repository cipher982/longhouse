# Unified zerg-ops policy

# Live Longhouse instance roots (each instance has longhouse.db)
LIVE_ROOT=/var/lib/docker/data/longhouse

# Where archives/manifests are stored locally
BACKUP_ROOT=/var/app-data/longhouse-backups
TMP_BACKUP_DIR=/var/app-data/longhouse-backups/tmp

# Empty = auto-discover all instance dirs with longhouse.db
# Example: INSTANCE_ALLOWLIST=david010,david-stripetest
INSTANCE_ALLOWLIST=
# Auto-discovery mode when allowlist is empty:
# running = only currently running longhouse-* containers (default)
# all = all dirs under LIVE_ROOT that contain longhouse.db
DISCOVERY_MODE=running

# Retention
KEEP_SNAPSHOTS=14
KEEP_DAYS_PRE=14
KEEP_DAYS_TMP=3

# Verification and cleanup behavior
VERIFY_ON_BACKUP=true
ENABLE_DOCKER_PRUNE=true
DOCKER_PRUNE_UNTIL_HOURS=240
ROOT_WARN_PCT=85

# Monitor policy (for zerg-ops monitor)
MONITOR_MAX_AGE_HOURS=30
# auto = require remote only when REMOTE_* is configured
# true/false = force behavior
MONITOR_REQUIRE_REMOTE=auto
# Optional alert webhook on monitor failures (Slack/Discord-compatible JSON)
ALERT_WEBHOOK_URL=

# Optional offsite sync (Synology/NAS)
# REMOTE_SSH_TARGET=drose@100.98.103.56
# REMOTE_BASE_PATH=/volume1/drose/backups/zerg-longhouse
REMOTE_SSH_TARGET=
REMOTE_BASE_PATH=
REMOTE_KEEP_SNAPSHOTS=30
