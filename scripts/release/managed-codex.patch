+fn server_notification_requires_delivery(notification: &ServerNotification) -> bool {
+    // Conservative allowlist: new notification variants default to best-effort until reviewed.
+    matches!(
+        notification,
+        ServerNotification::TurnCompleted(_)
+            | ServerNotification::ItemCompleted(_)
+            | ServerNotification::AgentMessageDelta(_)
+            | ServerNotification::PlanDelta(_)
+            | ServerNotification::ReasoningSummaryTextDelta(_)
+            | ServerNotification::ReasoningTextDelta(_)
+    )
+}
+
+fn outgoing_message_requires_delivery(message: &OutgoingMessage) -> bool {
+    match message {
+        OutgoingMessage::AppServerNotification(notification) => {
+            server_notification_requires_delivery(notification)
+        }
+        OutgoingMessage::Request(_) | OutgoingMessage::Response(_) | OutgoingMessage::Error(_) => {
+            true
+        }
+    }
+}
