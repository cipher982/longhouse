+                auth_token: self.remote_app_server_auth_token.clone(),
+            },
+            self.environment_manager.clone(),
+        )
+        .await
+        {
+            Ok(app_server) => app_server.with_remote_cwd_override(remote_cwd_override),
+            Err(err) => {
+                self.chat_widget.add_error_message(format!(
+                    "Remote app-server disconnected and reconnect failed: {err}"
+                ));
+                return Ok(false);
+            }
+        };
+
+        match replacement.resume_thread(self.config.clone(), thread_id).await {
+            Ok(resumed) => {
+                *app_server = replacement;
+                self.replace_chat_widget_with_app_server_thread(tui, app_server, resumed)
+                    .await?;
+                self.chat_widget.add_info_message(
+                    "Recovered remote Codex connection.".to_string(),
+                    None,
+                );
+                Ok(true)
+            }
+            Err(err) => {
+                self.chat_widget.add_error_message(format!(
+                    "Remote app-server disconnected and resume failed: {err}"
+                ));
+                self.chat_widget.add_error_message(disconnect_message);
+                Ok(false)
+            }
+        }
+    }
