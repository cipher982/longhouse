+    async fn reconnect_remote_app_server(
+        &mut self,
+        tui: &mut tui::Tui,
+        app_server: &mut AppServerSession,
+        disconnect_message: String,
+    ) -> Result<bool> {
+        let Some(websocket_url) = self.remote_app_server_url.clone() else {
+            return Ok(false);
+        };
+        let Some(thread_id) = self.current_displayed_thread_id().or(self.primary_thread_id) else {
+            return Ok(false);
+        };
+
+        let remote_cwd_override = app_server.remote_cwd_override().map(|cwd| cwd.to_path_buf());
+        let mut replacement = match crate::start_app_server_for_picker(
