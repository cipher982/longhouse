      "native_target_command": "longhouse claude",
      "phase1_inventory_ids": [
        "claude-launch-wrapper",
        "claude-channel-bridge",
        "claude-channel-helpers",
        "claude-permission-gate-hook-python",
        "control-channel-claude-shellout"
      ],
      "providers": [
        "claude"
      ],
      "provider_binary_ownership": "user_owned",
      "token_policy": "env_or_state_file",
      "cwd_policy": "strict_absolute_or_existing",
      "notes": "The public native facade owns Claude launch/configure and delegates channel mechanics only to its paired native engine. Python commands remain explicit longhouse-python compatibility. Installed-provider lifecycle proof is still required before release."
    },
    {
