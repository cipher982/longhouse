{
  "schema_version": 1,
  "native_owner": {
    "binary": "longhouse",
    "namespace": "public facade",
    "status": "native"
  },
  "compatibility_shims": [
    {
      "script": "longhouse-python",
      "target": "zerg.cli.main:main",
      "status": "legacy_server_compatibility",
      "delegates_to": "longhouse-python (server compatibility only)",
      "phase1_inventory_ids": [
        "cli-main-provider-entrypoints"
      ],
      "removal_phase": "device cutover"
    },
    {
      "script": "longhouse-python-local-health",
      "target": "zerg.cli.local_health_fast:main",
      "status": "legacy_server_compatibility",
      "delegates_to": "longhouse-python (server compatibility only)",
      "phase1_inventory_ids": [
        "local-health-fast-cli-python"
      ],
      "removal_phase": "device cutover"
    }
  ],
  "commands": [
    {
      "id": "device-root",
      "status": "implemented",
      "implementation_phase": "device cutover",
      "legacy_commands": [
        "longhouse",
        "longhouse --help"
      ],
      "native_target_command": "longhouse",
      "phase1_inventory_ids": [
        "cli-main-provider-entrypoints",
        "cli-common-scaffold",
        "cli-launch-ui-scaffold",
        "cli-managed-contract-scaffold"
      ],
      "providers": "all",
      "provider_binary_ownership": "not_applicable",
      "token_policy": "not_applicable",
      "cwd_policy": "not_applicable",
      "notes": "Public native facade owns normal installed-device commands and delegates internal mechanics only to its paired engine. Python is server compatibility only."
    },
    {
      "id": "local-health",
      "status": "implemented_fast_snapshot",
      "implementation_phase": "device cutover",
      "legacy_commands": [
        "longhouse local-health",
        "longhouse-local-health",
        "Longhouse.app menu-bar health refresh"
      ],
      "native_target_command": "longhouse local-health --fast --json",
      "phase1_inventory_ids": [
        "local-health-cli-python",
        "local-health-fast-cli-python",
        "local-health-service-python",
        "desktop-app-health-launcher-python"
      ],
      "providers": "all",
      "provider_binary_ownership": "not_applicable",
      "token_policy": "no_token",
      "cwd_policy": "not_applicable",
      "notes": "The public facade delegates the Desktop-facing fast JSON snapshot to the paired engine. Rich Python local-health remains server compatibility only until its data contract is ported."
    },
    {
      "id": "machine-repair",
      "status": "implemented",
      "implementation_phase": "device cutover",
      "legacy_commands": [
        "longhouse machine repair"
      ],
      "native_target_command": "longhouse machine repair",
      "phase1_inventory_ids": [
        "machine-cli-python"
      ],
      "providers": "all",
      "provider_binary_ownership": "not_applicable",
      "token_policy": "env_or_state_file",
      "cwd_policy": "not_applicable",
      "notes": "Native repair provides read-only recommendations and a narrow write-capable action that can restart only an existing configured launchd/systemd Machine Agent service after LONGHOUSE_HOME safety checks. Full install, desktop artifact repair, backlog replay, and token rotation remain separate explicit work; token values stay out of argv and logs."
    },
    {
      "id": "native-machine-setup",
      "status": "implemented",
      "implementation_phase": "device cutover",
      "legacy_commands": [
        "longhouse connect --install",
        "longhouse doctor"
      ],
      "native_target_command": "longhouse auth --url <runtime-url> && longhouse machine repair --repair-service",
      "phase1_inventory_ids": [
        "doctor-cli-python",
        "device-hook-installer-python"
      ],
      "providers": "all",
      "provider_binary_ownership": "not_applicable",
      "token_policy": "not_applicable",
      "cwd_policy": "not_applicable",
      "notes": "Native first install stores a device token supplied only through LONGHOUSE_DEVICE_TOKEN, then writes and activates the paired Machine Agent service. `longhouse connect --install` and `longhouse doctor` are not normal-device commands; server compatibility remains explicit under longhouse-python."
    },
    {
      "id": "auth",
      "status": "implemented",
      "implementation_phase": "device cutover",
      "legacy_commands": [
        "longhouse auth"
      ],
      "native_target_command": "longhouse auth --url <runtime-url>",
      "phase1_inventory_ids": [
        "cli-main-provider-entrypoints",
        "cli-common-scaffold"
      ],
      "providers": "all",
      "provider_binary_ownership": "not_applicable",
      "token_policy": "env_or_state_file",
      "cwd_policy": "not_applicable",
      "notes": "Native auth validates a device token supplied through LONGHOUSE_DEVICE_TOKEN (or --token-env), then atomically updates canonical machine state and the private token file. It intentionally never accepts a token argument."
    },
    {
      "id": "provider-live-proof",
      "status": "planned",
      "implementation_phase": "phase7",
      "legacy_commands": [
        "longhouse provider-live publish",
        "longhouse provider-live canary"
      ],
      "native_target_command": "longhouse provider-live",
      "phase1_inventory_ids": [
        "provider-live-cli-python"
      ],
      "providers": "all",
      "provider_binary_ownership": "user_owned",
      "token_policy": "env_or_state_file",
      "cwd_policy": "not_applicable",
      "notes": "Native provider proof should keep provider CLIs user-owned and keep proof upload tokens out of argv."
    },
    {
      "id": "claude-managed",
      "status": "implemented",
      "implementation_phase": "device cutover",
      "legacy_commands": [
