      "cwd_policy": "strict_absolute_or_existing",
      "notes": "The public native facade owns Codex launch/attach/stop and delegates bridge mechanics only to its paired native engine. Python commands remain explicit longhouse-python compatibility. Installed-provider lifecycle proof is still required before release."
    },
    {
      "id": "opencode-managed",
      "status": "implemented",
      "implementation_phase": "device cutover",
      "legacy_commands": [
        "longhouse opencode",
        "longhouse opencode-channel attach",
        "longhouse opencode-bridge"
