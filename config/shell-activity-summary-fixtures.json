{
  "version": 1,
  "cases": [
    {
      "name": "repeated recognizable operation",
      "calls": [
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 1
            }
          ]
        }
      ],
      "expected": "Ran gh run view ×2"
    },
    {
      "name": "semantic salience wins before shell naming",
      "calls": [
        {
          "category": "read"
        },
        {
          "category": "edit"
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 1
            }
          ]
        }
      ],
      "expected": "Read 1 · Edited 1 · Ran gh run view"
    },
    {
      "name": "display budget brackets distinct overflow chronologically",
      "calls": [
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "make test",
              "label": "make test",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "docker compose up",
              "label": "docker compose up",
              "count": 1
            }
          ]
        }
      ],
      "expected": "Ran gh run view · docker compose up · +1 more"
    },
    {
      "name": "named and opaque work remain honest",
      "calls": [
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 1
            }
          ]
        },
        {
          "category": "run"
        },
        {
          "category": "run"
        }
      ],
      "expected": "Ran gh run view · +2 other"
    },
    {
      "name": "first and last survive a noisy edit verification commit group",
      "calls": [
        {
          "category": "edit"
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "git add",
              "label": "git add",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "git diff",
              "label": "git diff",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "go test",
              "label": "go test",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "git status",
              "label": "git status",
              "count": 1
            }
          ]
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "git commit",
              "label": "git commit",
              "count": 1
            }
          ]
        },
        {
          "category": "run"
        },
        {
          "category": "wait"
        },
        {
          "category": "wait"
        },
        {
          "category": "wait"
        },
        {
          "category": "wait"
        }
      ],
      "expected": "Edited 1 · Ran git add · git commit · +3 more · +1 other · Waited 4"
    },
    {
      "name": "all opaque falls back to count",
      "calls": [
        {
          "category": "run"
        },
        {
          "category": "run"
        }
      ],
      "expected": "Ran 2"
    },
    {
      "name": "one call may contain repeated literal operations",
      "calls": [
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 2
            }
          ]
        }
      ],
      "expected": "Ran gh run view ×2"
    },
    {
      "name": "wait retains fixed category order",
      "calls": [
        {
          "category": "wait"
        },
        {
          "category": "run",
          "operations": [
            {
              "key": "gh run view",
              "label": "gh run view",
              "count": 1
            }
          ]
        }
      ],
      "expected": "Ran gh run view · Waited 1"
    },
    {
      "name": "edit names its file and diff stat",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "web/src/lib/sessionWorkspace/timelineModel.ts",
            "old_string": "a\nb\nc",
            "new_string": "a\nB\nc"
          }
        },
        {
          "category": "read"
        }
      ],
      "expected": "Read 1 · Edited timelineModel.ts +1 −1"
    },
    {
      "name": "edited files deduplicate by path",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "a.ts",
            "old_string": "x",
            "new_string": "y"
          }
        },
        {
          "category": "edit",
          "input": {
            "file_path": "b.ts",
            "old_string": "x",
            "new_string": "y"
          }
        },
        {
          "category": "edit",
          "input": {
            "file_path": "a.ts",
            "old_string": "y",
            "new_string": "z"
          }
        }
      ],
      "expected": "Edited a.ts +1 −1 · b.ts +1 −1"
    },
    {
      "name": "edited files overflow after two distinct paths",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "a.ts",
            "old_string": "x",
            "new_string": "y"
          }
        },
        {
          "category": "edit",
          "input": {
            "file_path": "b.ts",
            "old_string": "x",
            "new_string": "y"
          }
        },
        {
          "category": "edit",
          "input": {
            "file_path": "c.ts",
            "old_string": "x",
            "new_string": "y"
          }
        }
      ],
      "expected": "Edited a.ts +1 −1 · b.ts +1 −1 · +1 more"
    },
    {
      "name": "write shape counts added lines only",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "new.ts",
            "content": "one\ntwo\nthree"
          }
        }
      ],
      "expected": "Edited new.ts +3 −0"
    },
    {
      "name": "apply_patch counts hunk lines",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "p.ts",
            "patch": "--- a/p.ts\n+++ b/p.ts\n@@\n-old\n+new\n+extra"
          }
        }
      ],
      "expected": "Edited p.ts +2 −1"
    },
    {
      "name": "unknown edit shape names the file without a stat",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "mystery.ts",
            "mode": "rewrite"
          }
        }
      ],
      "expected": "Edited mystery.ts"
    },
    {
      "name": "edit with no recoverable input falls back to a count",
      "calls": [
        {
          "category": "edit",
          "input": {}
        },
        {
          "category": "edit",
          "input": {}
        }
      ],
      "expected": "Edited 2"
    },
    {
      "name": "named and unnamed edits fold into one overflow count",
      "calls": [
        {
          "category": "edit",
          "input": {
            "file_path": "a.ts",
            "old_string": "x",
            "new_string": "y"
          }
        },
        {
          "category": "edit",
          "input": {}
        }
      ],
      "expected": "Edited a.ts +1 −1 · +1 more"
    }
  ]
}
