{
  "$comment": "Single source of truth for all LLM model configuration across Longhouse",

  "text": {
    "$comment": "Text/chat completion models (Zerg agent orchestration)",
    "tiers": {
      "TIER_1": "gpt-5.2",
      "TIER_2": "gpt-5-mini",
      "TIER_3": "gpt-5-nano"
    },
    "models": {
      "gpt-5.2": {
        "displayName": "GPT-5.2",
        "provider": "openai",
        "tier": "TIER_1",
        "description": "Latest state-of-the-art reasoning capability",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "gpt-5-mini": {
        "displayName": "GPT-5 Mini",
        "provider": "openai",
        "tier": "TIER_2",
        "description": "Good quality, lower cost",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": false
        }
      },
      "gpt-5-nano": {
        "displayName": "GPT-5 Nano",
        "provider": "openai",
        "tier": "TIER_3",
        "description": "Fast and cheap, basic capability",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": false
        }
      },
      "deepseek/deepseek-v4-pro": {
        "displayName": "DeepSeek v4 Pro (OpenRouter)",
        "provider": "openrouter",
        "description": "DeepSeek v4 Pro via OpenRouter - main default for text routing (large context)",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "minimax/minimax-m2.7": {
        "displayName": "MiniMax M2.7 (OpenRouter)",
        "provider": "openrouter",
        "description": "MiniMax M2.7 via OpenRouter - fallback, ~200K ctx limit",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "deepseek/deepseek-v4-flash": {
        "displayName": "DeepSeek v4 Flash (OpenRouter)",
        "provider": "openrouter",
        "description": "DeepSeek v4 Flash via OpenRouter - fallback for high-volume summarization",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "x-ai/grok-4.3": {
        "displayName": "Grok 4.3 (OpenRouter)",
        "provider": "openrouter",
        "description": "xAI Grok 4.3 via OpenRouter - flagship fallback for harder tasks",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "openai/gpt-5-mini": {
        "displayName": "GPT-5 Mini (OpenRouter)",
        "provider": "openrouter",
        "description": "OpenAI GPT-5 Mini via OpenRouter",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": false
        }
      }
    }
  },

  "realtime": {
    "$comment": "Realtime/voice models",
    "tiers": {
      "TIER_1": "gpt-4o-realtime-preview",
      "TIER_2": "gpt-4o-mini-realtime-preview"
    },
    "models": {
      "gpt-4o-realtime-preview": {
        "displayName": "GPT-4o Realtime",
        "provider": "openai",
        "tier": "TIER_1",
        "description": "Full capability realtime model"
      },
      "gpt-4o-mini-realtime-preview": {
        "displayName": "GPT-4o Mini Realtime",
        "provider": "openai",
        "tier": "TIER_2",
        "description": "Faster, cheaper realtime model"
      }
    },
    "aliases": {
      "gpt-realtime": "gpt-4o-realtime-preview",
      "gpt-4-realtime": "gpt-4o-realtime-preview"
    },
    "defaultVoice": "verse"
  },

  "useCases": {
    "$comment": "Maps use cases to tiers - quality-critical tasks get TIER_1 even for small outputs",
    "text": {
      "fiche_conversation": "TIER_1",
      "loop_controller": "deepseek/deepseek-v4-pro",
      "routing_decision": "TIER_1",
      "tool_selection": "TIER_1",
      "commis_task": "TIER_1",
      "summarization": "TIER_2",
      "summary_update": "TIER_3",
      "reflection": "TIER_2",
      "bulk_classification": "TIER_3",
      "ci_test": "TIER_3"
    },
    "realtime": {
      "voice_conversation": "TIER_1",
      "voice_test": "TIER_2"
    }
  },

  "routingProfiles": {
    "$comment": "Optional per-instance overrides. Select with MODELS_PROFILE (default: oss). Hosted uses OpenRouter for unified provider access.",
    "oss": {
      "$comment": "Default OSS profile: no overrides, uses direct provider tiers"
    },
    "hosted": {
      "$comment": "Hosted instances: all internal tasks route through OpenRouter. Commis/agent execution is NOT here — those spawn CLI agents with their own model selection via hatch.",
      "text": {
        "useCases": {
          "fiche_conversation": "deepseek/deepseek-v4-pro",
          "summarization": "deepseek/deepseek-v4-pro",
          "summary_update": "deepseek/deepseek-v4-pro",
          "reflection": "deepseek/deepseek-v4-pro",
          "bulk_classification": "deepseek/deepseek-v4-pro"
        },
        "defaults": {
          "fiche": "deepseek/deepseek-v4-pro",
          "test": "deepseek/deepseek-v4-pro"
        }
      }
    },
    "david": {
      "$comment": "David's instance: use OpenRouter for text routing; embeddings stay on the embedding provider.",
      "text": {
        "useCases": {
          "fiche_conversation": "deepseek/deepseek-v4-pro",
          "summarization": "deepseek/deepseek-v4-pro",
          "summary_update": "deepseek/deepseek-v4-pro",
          "reflection": "deepseek/deepseek-v4-pro",
          "bulk_classification": "deepseek/deepseek-v4-pro"
        },
        "defaults": {
          "fiche": "deepseek/deepseek-v4-pro",
          "test": "deepseek/deepseek-v4-pro"
        }
      }
    }
  },

  "defaults": {
    "text": {
      "fiche": "TIER_1",
      "commis": "TIER_1",
      "test": "TIER_3"
    },
    "realtime": {
      "production": "TIER_1",
      "test": "TIER_2"
    }
  },

  "embedding": {
    "default": {
      "provider": "openai",
      "model": "text-embedding-3-small",
      "dims": 256,
      "apiKeyEnvVar": "OPENAI_API_KEY"
    }
  }
}
