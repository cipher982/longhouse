{
  "$comment": "Single source of truth for all LLM model configuration across Longhouse",

  "text": {
    "$comment": "Text/chat completion models (Zerg agent orchestration)",
    "tiers": {
      "TIER_1": "deepseek/deepseek-v4-pro",
      "TIER_2": "deepseek/deepseek-v4-flash",
      "TIER_3": "deepseek/deepseek-v4-flash"
    },
    "models": {
      "deepseek/deepseek-v4-pro": {
        "displayName": "DeepSeek v4 Pro (OpenRouter)",
        "provider": "openrouter",
        "tier": "TIER_1",
        "description": "DeepSeek v4 Pro via OpenRouter - primary reasoning and interactive automation lane",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "deepseek/deepseek-v4-flash": {
        "displayName": "DeepSeek v4 Flash (OpenRouter)",
        "provider": "openrouter",
        "tier": "TIER_2",
        "description": "DeepSeek v4 Flash via OpenRouter - primary for high-volume summarization and reflection lanes",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "google/gemini-3.1-flash-lite:nitro": {
        "displayName": "Gemini 3.1 Flash Lite Nitro (OpenRouter)",
        "provider": "openrouter",
        "tier": "TIER_3",
        "description": "Gemini 3.1 Flash Lite via OpenRouter Nitro - low-latency first-message session title lane",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": false,
          "reasoningNone": true
        }
      }
    }
  },

  "realtime": {
    "$comment": "Realtime/voice models",
    "tiers": {
      "TIER_1": "gpt-4o-realtime-preview",
      "TIER_2": "gpt-4o-mini-realtime-preview"
    },
    "models": {
      "gpt-4o-realtime-preview": {
        "displayName": "GPT-4o Realtime",
        "provider": "openai",
        "tier": "TIER_1",
        "description": "Full capability realtime model"
      },
      "gpt-4o-mini-realtime-preview": {
        "displayName": "GPT-4o Mini Realtime",
        "provider": "openai",
        "tier": "TIER_2",
        "description": "Faster, cheaper realtime model"
      }
    },
    "aliases": {
      "gpt-realtime": "gpt-4o-realtime-preview",
      "gpt-4-realtime": "gpt-4o-realtime-preview"
    },
    "defaultVoice": "verse"
  },

  "useCases": {
    "$comment": "Maps active text use cases to the two standard Longhouse lanes.",
    "text": {
      "session_title": "google/gemini-3.1-flash-lite:nitro",
      "summarization": "TIER_2",
      "summary_update": "TIER_3"
    },
    "realtime": {
      "voice_conversation": "TIER_1",
      "voice_test": "TIER_2"
    }
  },

  "defaults": {
    "text": {
      "primary": "TIER_1",
      "test": "TIER_3"
    },
    "realtime": {
      "production": "TIER_1",
      "test": "TIER_2"
    }
  },

  "embedding": {
    "default": {
      "provider": "openrouter",
      "model": "openai/text-embedding-3-small",
      "dims": 256,
      "baseUrl": "https://openrouter.ai/api/v1",
      "apiKeyEnvVar": "OPENROUTER_API_KEY"
    }
  }
}
