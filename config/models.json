{
  "$comment": "Single source of truth for all LLM model configuration across Zerg and Oikos",

  "text": {
    "$comment": "Text/chat completion models (Zerg agent orchestration)",
    "tiers": {
      "TIER_1": "gpt-5.2",
      "TIER_2": "gpt-5-mini",
      "TIER_3": "gpt-5-nano"
    },
    "models": {
      "gpt-5.2": {
        "displayName": "GPT-5.2",
        "provider": "openai",
        "tier": "TIER_1",
        "description": "Latest state-of-the-art reasoning capability",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "gpt-5-mini": {
        "displayName": "GPT-5 Mini",
        "provider": "openai",
        "tier": "TIER_2",
        "description": "Good quality, lower cost",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": false
        }
      },
      "gpt-5-nano": {
        "displayName": "GPT-5 Nano",
        "provider": "openai",
        "tier": "TIER_3",
        "description": "Fast and cheap, basic capability",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": false
        }
      },
      "x-ai/grok-4.1-fast": {
        "displayName": "Grok 4.1 Fast (OpenRouter)",
        "provider": "openrouter",
        "description": "xAI Grok 4.1 fast via OpenRouter - reasoning normalized automatically",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "x-ai/grok-4": {
        "displayName": "Grok 4 (OpenRouter)",
        "provider": "openrouter",
        "description": "xAI Grok 4 full via OpenRouter - top-tier quality",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true
        }
      },
      "openai/gpt-5-mini": {
        "displayName": "GPT-5 Mini (OpenRouter)",
        "provider": "openrouter",
        "description": "OpenAI GPT-5 Mini via OpenRouter",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnvVar": "OPENROUTER_API_KEY",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": false
        }
      },
      "grok-4-1-fast-reasoning": {
        "displayName": "Grok 4.1 Fast (Reasoning, direct xAI)",
        "provider": "xai",
        "description": "xAI Grok 4.1 fast direct - legacy, prefer OpenRouter",
        "baseUrl": "https://api.x.ai/v1",
        "apiKeyEnvVar": "XAI_API_KEY",
        "capabilities": {
          "reasoning": true
        }
      },
      "grok-4-1-fast-non-reasoning": {
        "displayName": "Grok 4.1 Fast (direct xAI)",
        "provider": "xai",
        "description": "xAI Grok 4.1 fast direct - legacy, prefer OpenRouter",
        "baseUrl": "https://api.x.ai/v1",
        "apiKeyEnvVar": "XAI_API_KEY",
        "capabilities": {
          "reasoning": false
        }
      },
      "meta-llama/llama-4-scout-17b-16e-instruct": {
        "displayName": "Llama 4 Scout (Groq)",
        "provider": "groq",
        "description": "Meta's Llama 4 Scout via Groq LPU - blazing fast",
        "baseUrl": "https://api.groq.com/openai/v1",
        "capabilities": {
          "reasoning": false
        }
      },
      "qwen/qwen3-32b": {
        "displayName": "Qwen 3 32B (Groq)",
        "provider": "groq",
        "description": "Alibaba's Qwen 3 32B via Groq LPU - fast general purpose",
        "baseUrl": "https://api.groq.com/openai/v1",
        "capabilities": {
          "reasoning": true,
          "reasoningNone": true
        }
      },
      "glm-4.7": {
        "displayName": "GLM 4.7 (z.ai)",
        "provider": "anthropic",
        "description": "Zhipu GLM-4.7 via z.ai Anthropic-compatible API",
        "baseUrl": "https://api.z.ai/api/anthropic",
        "apiKeyEnvVar": "ZAI_API_KEY",
        "capabilities": {
          "reasoning": true
        }
      },
      "glm-4.7-flash": {
        "displayName": "GLM 4.7 Flash (z.ai Free)",
        "provider": "anthropic",
        "description": "Free-tier GLM-4.7 Flash - good enough for summarization",
        "baseUrl": "https://api.z.ai/api/anthropic",
        "apiKeyEnvVar": "ZAI_API_KEY",
        "capabilities": {
          "reasoning": false
        }
      }
    }
  },

  "realtime": {
    "$comment": "Realtime/voice models (Oikos voice interface)",
    "tiers": {
      "TIER_1": "gpt-4o-realtime-preview",
      "TIER_2": "gpt-4o-mini-realtime-preview"
    },
    "models": {
      "gpt-4o-realtime-preview": {
        "displayName": "GPT-4o Realtime",
        "provider": "openai",
        "tier": "TIER_1",
        "description": "Full capability realtime model"
      },
      "gpt-4o-mini-realtime-preview": {
        "displayName": "GPT-4o Mini Realtime",
        "provider": "openai",
        "tier": "TIER_2",
        "description": "Faster, cheaper realtime model"
      }
    },
    "aliases": {
      "gpt-realtime": "gpt-4o-realtime-preview",
      "gpt-4-realtime": "gpt-4o-realtime-preview"
    },
    "defaultVoice": "verse"
  },

  "useCases": {
    "$comment": "Maps use cases to tiers - quality-critical tasks get TIER_1 even for small outputs",
    "text": {
      "fiche_conversation": "TIER_1",
      "routing_decision": "TIER_1",
      "tool_selection": "TIER_1",
      "commis_task": "TIER_1",
      "summarization": "TIER_2",
      "summary_update": "TIER_3",
      "reflection": "TIER_2",
      "bulk_classification": "TIER_3",
      "ci_test": "TIER_3"
    },
    "realtime": {
      "voice_conversation": "TIER_1",
      "voice_test": "TIER_2"
    }
  },

  "routingProfiles": {
    "$comment": "Optional per-instance overrides. Select with MODELS_PROFILE (default: oss). Hosted uses OpenRouter for unified provider access.",
    "oss": {
      "$comment": "Default OSS profile: no overrides, uses direct provider tiers"
    },
    "hosted": {
      "$comment": "Hosted instances: all internal tasks route through OpenRouter. Commis/agent execution is NOT here — those spawn CLI agents with their own model selection via hatch.",
      "text": {
        "useCases": {
          "fiche_conversation": "x-ai/grok-4.1-fast",
          "summarization": "x-ai/grok-4.1-fast",
          "summary_update": "x-ai/grok-4.1-fast",
          "reflection": "x-ai/grok-4.1-fast",
          "bulk_classification": "x-ai/grok-4.1-fast"
        },
        "defaults": {
          "fiche": "x-ai/grok-4.1-fast",
          "test": "x-ai/grok-4.1-fast"
        }
      }
    },
    "david": {
      "$comment": "David's instance: OpenRouter for summarization",
      "text": {
        "useCases": {
          "summarization": "x-ai/grok-4.1-fast",
          "summary_update": "x-ai/grok-4.1-fast"
        }
      }
    }
  },

  "defaults": {
    "text": {
      "fiche": "TIER_1",
      "commis": "TIER_1",
      "test": "TIER_3"
    },
    "realtime": {
      "production": "TIER_1",
      "test": "TIER_2"
    }
  },

  "embedding": {
    "default": {
      "provider": "openai",
      "model": "text-embedding-3-small",
      "dims": 256,
      "apiKeyEnvVar": "OPENAI_API_KEY"
    }
  }
}
